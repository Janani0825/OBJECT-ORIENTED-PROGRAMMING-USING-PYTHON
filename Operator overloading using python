class Shape:
    def area(self, *args):
        if len(args) == 1:
            r = args[0]
            print("Area of circle:", 3.14 * r * r)
        elif len(args) == 2:
            l, b = args
            print("Area of rectangle:", l * b)
        elif len(args) == 3:
            a, b, c = args
            s = (a + b + c) / 2
            area = (s * (s - a) * (s - b) * (s - c)) ** 0.5
            print("Area of triangle:", area)
        else:
            print("INVALID NUMBER OF ARGUMENTS")
s = Shape()
s.area(5)
s.area(6, 5)
s.area(3, 4, 5)

