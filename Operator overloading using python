class Student:
    def __init__(self):
        self.name = ""
        self.age = 0
        self.grade = ""
    def get_input(self):
        self.name = input("Enter student's name: ")
        self.age = int(input("Enter student's age: "))
        self.grade = input("Enter student's grade: ")
    def display(self):
        print(f"Name: {self.name}")
        print(f"Age: {self.age}")
        print(f"Grade: {self.grade}")
class CustomStudent(Student):
    def get_input(self):
        print("Please provide the student details.")
        super().get_input()
student = CustomStudent()
student.get_input()
student.display()

