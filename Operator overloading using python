class Book:
   def __init__(self,title,author,price):
      self.title=title
      self.author=author
      self.price=price
   def display_book(self):
      print("Book title:",self.title)
      print("Book author:",self.author)
      print("Book price:",self.price)
   def __add__(self,other):
      return (self.price+other.price)
p=[]
n=int(input("Enter the limit:"))
for i in range(n):
   book=input("Enter the book title:")
   author=input("Enter the book author:")
   price=int(input("Enter the book price:Rs"))
   var_book=input("Enter the other book title:")
   var_author=input("Enter the other book author:")
   var_price=int(input("Enter the other book price:Rs"))
   b1=Book(book,author,price)
   b2=Book(var_book,var_author,var_price)
   b=b1+b2
   p.append(b)
from functools import *
l=reduce(lambda a,b:a+b,p)
print("Total price:Rs",l)
