class Complex_num:
   def __init__(self,real,imag):
      self.real=real
      self.imag=imag
   def __add__(self,other):
      real1=self.real+other.real
      imag1=self.imag+other.imag
      return complex(real1,imag1)
   def __sub__(self,other):
      real2=self.real-other.real
      imag2=self.imag-other.imag
      return complex(real2,imag2)
   def __mul__(self,other):
      real3=(self.real*other.real)-(self.imag*other.imag)
      imag3=(self.real*other.imag)+(self.imag*other.real)
      return complex(real3,imag3)
n=int(input("Enter the limit:"))
for i in range(n):
   real=int(input("Enter the real part:"))
   imag=int(input("Enter the imaginary part:"))
   a=Complex_num(real,imag)
   var_real=int(input("Enter the variable real part:"))
   var_imag=int(input("Enter the variable imaginary part:"))
   b=Complex_num(var_real,var_imag)
   print("Given number1:",complex(real,imag))
   print("Given number2:",complex(var_real,var_imag))
   print("Addition:",a+b)
   print("Subtraction:",a-b)
   print("Multiplication:",a*b)
