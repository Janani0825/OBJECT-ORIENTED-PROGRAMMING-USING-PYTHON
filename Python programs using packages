import numpy as np
print("------------------------BASIC NUMPY OPERATIONS-----------------------------")
arr=np.array([10,20,30,40])
print("1-D Array:",arr)
print("Array +5:",arr+5)
print("Arrayed squared :",arr**2)
print("Mean:",np.mean(arr))
print("Standard Deviation :",np.std(arr))
print("------------------------MATRIX OPERATIONS-----------------------------------")
A=np.array([[1,2],[3,4]])
B=np.array([[2,0],[1,3]])
print("Matrix A:\n",A)
print("Matrix B:\n",B)
print("A+B:\n",A+B)
print("A-B:\n",A-B)
print("A*B(element_wise):\n",A*B)
print("A@B(matrix multiplication):\n",np.dot(A,B))
print("Transpose of A:\n",A.T)

