class Shoppingbill:
    TAX_RATE = 0.05
    total_bills_created = 0

    def __init__(self):
        self.items = {}
        self.total_amount = 0
        self.get_items()
        self.total_with_tax = self.calculate_total()
        Shoppingbill.total_bills_created +=1

    def get_items(self):
        num_items = int(input("Enter number of items: "))
        for i in range(num_items):
            item_name = input(f"Enter the name of item {i + 1}: ")
            quantity = float(input(f"Enter quantity for {item_name}: "))
            price = float(input(f"Enter price for {item_name}: "))
            self.items[item_name] = price * quantity
            self.total_amount += price * quantity

    def calculate_total(self):
        return self.total_amount + (self.total_amount * Shoppingbill.TAX_RATE)

    def display_bill(self):
        print("----------------")
        print("\nSHOPPING BILLl")
        print("----------------")
        for item, cost in self.items.items():
            print(f"{item}: ${cost:.2f}")
        print(f"Total bill (including tax): ${self.total_with_tax:.2f}")
        print(f"Total bills created: {Shoppingbill.total_bills_created}")

    @staticmethod
    def calculate_discount(amount, discount_percentage):
        discount = amount * (discount_percentage / 100)
        return amount - discount
