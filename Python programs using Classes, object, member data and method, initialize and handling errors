class InsufficientFundsException(Exception):
    def __init__(self, message="WITHDRAW FAILED: INSUFFICIENT FUNDS!"):
        self.msg = message

class MinimumBalanceException(Exception):
    def __init__(self, message="WITHDRAW FAILED: MINIMUM BALANCE RS 500 REQUIRED!"):
        self.msg = message

class BankAccount:
    def __init__(self, account_holder, balance, address, mobile_number):
        self.account_holder = account_holder
        self.balance = balance
        self.address = address
        self.mobile_number = mobile_number

    def deposit(self, amount):
        if amount <= 0:
            print("Deposit amount should be positive.")
        else:
            self.balance += amount
            print("RS", amount, "deposited successfully! New balance: RS", self.balance)

    def withdraw(self, amount):
        if amount > self.balance:
            raise InsufficientFundsException()
        elif self.balance - amount < 500:
            raise MinimumBalanceException()
        else:
            self.balance -= amount
            print("RS", amount, "withdrawn successfully! Remaining balance: RS", self.balance)

    def check_balance(self):
        print("Account balance: RS", self.balance)

    def account_info(self):
        print("Account Holder:", self.account_holder)
        print("Address:", self.address)
        print("Mobile Number:", self.mobile_number)


try:
    n = int(input("Enter the number of accounts to create: "))
