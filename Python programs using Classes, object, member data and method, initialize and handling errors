        account.withdraw(withdraw_amount)

except InsufficientFundsException as e:
    print("Exception:", e.msg)
except MinimumBalanceException as e:
    print("Exception:", e.msg)
except ValueError:
    print("INVALID INPUT! PLEASE ENTER A VALID NUMBER")
