class AgeRestrictionException(Exception):
    def __init__(self, message="You are not allowed to ride."):
        self.message = message

class ThemePark:
    def __init__(self):
        self.allowed_rides = []

    def check_ride_eligibility(self, age):
        if age < 10:
            raise AgeRestrictionException("You must be at least 10 years old to ride certain rides.")
        elif age > 60:
            raise AgeRestrictionException("You are not allowed to ride any rides.")
        else:
            self.allowed_rides = ["Roller Coaster", "Ferris Wheel", "Bumper Cars"]
            return self.allowed_rides


