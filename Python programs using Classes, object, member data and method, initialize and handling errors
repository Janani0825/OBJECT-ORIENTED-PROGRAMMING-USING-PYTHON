class Person:
    def __init__(self, name, roll, dep):
        self.name = name
        self.roll = roll
        self.dep = dep

    def display(self):
        print("Name of student:", self.name)
        print("Roll no:", self.roll)
        print("Department:", self.dep)


class Student(Person):
    def __init__(self, name, roll, dep, marks):
        super().__init__(name, roll, dep)
        self.marks = marks
        self.avg = self.calculate_avg()

    def calculate_avg(self):
        return sum(self.marks) / len(self.marks) if self.marks else 0

    def display_marks(self):
        print("MARKS:", self.marks)
        print("AVERAGE:", self.avg)


class Result(Student):
    def __init__(self, name, roll, dep, marks):
        super().__init__(name, roll, dep, marks)
        self.grade = self.calculate_grade()

    def calculate_grade(self):
        if self.avg >= 90:
            return 'A'
        elif 80 < self.avg < 90:
            return 'B'
        elif 70 < self.avg < 80:
            return 'C'
        elif 60 < self.avg < 70:
            return 'D'
        else:
            return 'F'

    def display(self):
        super().display()  # Call the display method of Person
        print("GRADE:", self.grade)


