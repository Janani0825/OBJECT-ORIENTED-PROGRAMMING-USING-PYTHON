      self.sy.display_salary()
class Salary:
   def __init__(self,bp):
      self.bp=bp
      self.totalsal=self.calculate()
   def calculate(self):
      self.hra=0.1*self.bp
      self.da=0.2*self.bp
      self.pf=0.05*self.bp
      return(self.bp+self.hra+self.da-self.pf)
   def display_salary(self):
      print(f"the basic pay is {self.bp}")
      print(f"the salary is {self.totalsal}")
