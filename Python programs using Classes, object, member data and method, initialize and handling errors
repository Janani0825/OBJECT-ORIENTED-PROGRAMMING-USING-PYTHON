class Transaction(Customer):
   def __init__(self,account_no,accountholder_name,mobno,balance):
      super().__init__(account_no,accountholder_name,mobno)
      self.balance=balance
      self.deposit=self.depositcalculate()
      self.withdraw=self.withdrawcalculate()
      self.check_balance=self.check_balance()
   def depositcalculate(self):
      self.amount=float(input("Enter the amount to be deposited:"))
      if self.amount<=0:
          print("Deposit amount should be positive")
      else:
          self.balance+=self.amount
          print("RS",self.amount)
          print("Deposited successfully")
          print("NEW BALANCE : RS",self.balance)
   def withdrawcalculate(self):
       self.amount1=float(input("Enter the amount to be withdrawn:"))
       if self.amount1>self.balance:
           print("INSUFFICIENT FUND")
       else:
           self.balance-=self.amount1
           print("RS:",self.amount)
           print("Withdrawn succesfully")
           print("NEW BALANCE : RS",self.balance)
   def check_balance(self):
      print("Account balance: RS",self.balance)
   def display_transaction(self):
      print("Account balance:",self.balance)

