class InvalidInputException(Exception):
    def __init__(self, message="INVALID INPUT!"):
        self.msg = message

class MessBill:
    def __init__(self, id, name, department, no_of_days, veg_days, nonveg_days):
        self.id = id
        self.name = name
        self.department = department
        self.no_of_days = no_of_days
        self.veg_days = veg_days
        self.nonveg_days = nonveg_days
        self.veg_cost_per_day = 50
        self.nonveg_cost_per_day = 70

    def calculate_bill(self):
       if self.no_of_days < 0 or self.veg_days < 0 or self.nonveg_days < 0:
            raise InvalidInputException("Days cannot be negative.")
       if self.veg_days + self.nonveg_days > self.no_of_days:
            raise InvalidInputException("Total meal days exceed the number of days.")
       total_bill = (self.veg_days * self.veg_cost_per_day) + (self.nonveg_days * self.nonveg_cost_per_day)
       return total_bill


try:
