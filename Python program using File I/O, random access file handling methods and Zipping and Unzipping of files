import os
file_name="bookdata.txt"
def write_books():
    with open(file_name,"w")  as f:
        f.write("Bookid\ttitle\tauthor\tprice\n")
        f.write("402\tpython\tbala\t150\n")
        f.write("106\t400days\tchatenbhagat\t480\n107\thow to kill your family\tbella mackie\t150\n108\talchemist\tpaulochoelho\t399")
    print("BOOKS WRITTEN")
def read_books():
    if not os.path.exists(file_name):
        print("file does not exist")
        return
    with open(file_name,"r") as f:
        print("current position",f.tell())
        content=f.read()
        print(content)
        print("file position",f.tell())
def test_seek():
    with open(file_name,"r") as f:
        p=int(input("Enter the position:"))
        f.seek(p)
        line=f.readline()
        print(line)
while True:
   print("\tMENU")
