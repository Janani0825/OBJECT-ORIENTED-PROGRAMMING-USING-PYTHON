import os,sys
fn=input("Enter file name : ")
if os.path.isfile(fn):
   print("File exists : ",fn)
   f=open(fn,"r")
else:
   print("File does not exists : ",fn)
   sys.exit(0)
lc=wc=cc=0
for l in f:
   lc=lc+1
   cc=cc+len(l)
   w=l.split()
   wc=wc+len(w)
print("Number of lines count      : ",lc)
print("Number of words count      : ",wc)
print("Number of characters count : ",cc)
