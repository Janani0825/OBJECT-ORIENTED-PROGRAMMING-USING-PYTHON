import math
import random
def calculator():
    print("Simple Calculator using Math Module")
    print("Random Numbers will be generated between 1 and 100")
    num1, num2 = math.ceil(random.random() * 100), math.ceil(random.random() * 100)
    print(f"Generated Random Numbers: {num1}, {num2}")
    operation = input("Choose operation (+, -, *, /): ")

    if operation == '+':
        print(f"Result: {math.fsum([num1, num2])}")
    elif operation == '-':
        print(f"Result: {num1 - num2}")
    elif operation == '*':
        print(f"Result: {num1 * num2}")
    elif operation == '/' and num2 != 0:
        print(f"Result: {num1 / num2}")
    else:
        print("Invalid operation or division by zero.")

calculator()
