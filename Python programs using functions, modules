def calculate_bill(items):
    total = sum(item[1] * item[2] for item in items)
    return total
items = []
for i in range(4):
    name = input(f"Enter the name of item {i + 1}: ")
    price = float(input(f"Enter the price of {name}: "))
    quantity = int(input(f"Enter the quantity of {name}: "))
    items.append((name, price, quantity))
final_total = calculate_bill(items)
print("\n\t--- Shopping Cart Bill ---")
print("{:<20} {:>10} {:>10} {:>10}".format("Item", "Price (₹)", "Quantity", "Total (₹)"))
print("-"*50)
for item in items:
    total = item[1] * item[2]
    print("{:<20} {:>10.2f} {:>10} {:>10.2f}".format(item[0], item[1], item[2], total))
print("-"*55)
print("{:<20} {:>30.2f}".format("Final Total (₹)", final_total))
print("-"*55)

