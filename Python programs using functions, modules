def fibonacci(n):
   if n<=1:
      return n
   return fibonacci(n-1)+fibonacci(n-2)
terms=int(input("Enter the number of terms upto which you want:"))
print("Fibonacci series:")
for i in range (terms):
    print(fibonacci(i))
