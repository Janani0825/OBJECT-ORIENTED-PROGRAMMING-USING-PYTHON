while True:
   print("-------------------------------------------------------------")
   print("\tMENU")
   print("1.List Operations")
   print("2.Second largest element")
   print("3.Product of list elements")
   print("4.Frequency Generator")
   print("5.Exiting the program")
   print("--------------------------------------------------------------")
   choice=int(input("Enter the choice:"))
   if choice==1:
      mylist=[2,8,10,6,12,4]
      while True:
         print("MENU")
         print("1.Append")
         print("2.Delete")
         print("3.Insert")
         print("4.Maximum and minimum")
         print("5.Exit")
         ch=int(input("Enter the choice:"))
         if ch==1:
            n=int(input("Enter the element to append:"))
            mylist.append(n)
            print("Updated List:",mylist)
         elif ch==2:
            n=int(input("Entr an element to delete:"))
            if n in mylist:
               mylist.remove(n)
            print("Updated list:",mylist)
         elif ch==3:
            n=int(input("Enter an element to insert:"))
            pos=int(input("Enter position:"))
            mylist.insert(pos,n)
            print("Updated list:",mylist)
         elif ch==4:
            print("Maximum element:",max(mylist))
            print("Minimum element:",min(mylist))
         else:
            print("Exiting the list operations...")
            break
   elif choice==2:
      num=list(map(int,input("Enter numbers seperated by space:").split()))
      unique=list(set(num))
      unique.sort(reverse=True)
      if len(unique)>1:
         print("Second largest number:",unique[1])
      else:
         print("No elements")
   elif choice==3:
      num=list(map(int,input("Enter numbers seperated by space:").split()))
      product=1
      for i in num:
         product*=i
      print("Product of list elements:",product)
   elif choice==4:
      n=list(map(int,input("Enter numbers seperated by space:").split()))
      freq=int(input("Enter the required frequency:"))
      result=[num for num in set(n) if n.count(num)==freq]
      print("Elements with frequency",freq,":",result)
   elif choice==5:
      print("Exiting the program")
      break
   else:
      print("Invalid choice...")

