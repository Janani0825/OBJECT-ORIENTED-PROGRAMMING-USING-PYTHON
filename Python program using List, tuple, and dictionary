while(True):
   print("-----------------------------------")
   print("\tMENU")
   print("-----------------------------------")
   print("1.Set operations")
   print("2.Occurences")
   print("3.Missing an extra element")
   print("4.Exit")
   print("-----------------------------------")
   choice=int(input("Enter a choice:"))
   if choice==1:
      set1=set(map(int,input("Enter first set seperated by space:").split()))
      set2=set(map(int,input("Enter second set seperated by space:").split()))
      while True:
         print("\tMenu")
         print("1.Union")
         print("2.Intersection")
         print("3.Difference")
         print("4.Symmetric Difference")
         print("5.Exit")
         ch=int(input("Enter your choice:"))
         if ch==1:
            print("Union:",set1|set2)
         elif ch==2:
            print("Intersection:",set1&set2)
         elif ch==3:
            print("Difference:",set1-set2)
         elif ch==4:
            print("Symmetric Difference:",set1^set2)
         elif ch==5:
            print("Exiting the program...")
            break
         else:
            print("Invalid choice")
   elif choice==2:
      words=list(input("Enter elements seperated by space:").split())
      occurences={word + ":" + str(words.count(word)) for word in set(words)}
      print(occurences)
   elif choice==3:
      set1=set(map(int,input("Enter elements of first set seperated by space:").split()))
      set2=set(map(int,input("Enter elements of second set seperated by space:").split()))
      missing=set2-set1
      extra=set1-set2
      print("Missing elements in set1:",missing)
      print("Extra elements in set2:",extra)
   elif choice==4:
      print("Exiting the program....")
      break
   else:print("Invalid choice...")

